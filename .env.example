# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Admin settings for /admin and /admin/rfq
ADMIN_USER="admin"
ADMIN_PASSWORD="change-this-password"
ADMIN_SESSION_SECRET="change-this-random-secret"
RFQ_DATA_DIR="./data/rfq"
BLOG_DATA_DIR="./data/blog"

# Blog translation AI provider.
# Default provider is "openai-responses" when no custom base URL is set.
# Use "openai-compatible" for DeepSeek, SiliconFlow, Qwen-compatible gateways, local LLM gateways, etc.
AI_TRANSLATION_PROVIDER="openai-compatible"
AI_TRANSLATION_API_KEY="your-ai-provider-key"
AI_TRANSLATION_MODEL="your-model-name"
AI_TRANSLATION_BASE_URL="https://api.openai.com/v1"

# Optional: set a full endpoint instead of AI_TRANSLATION_BASE_URL.
# For openai-compatible this should point to /chat/completions.
# For openai-responses this should point to /responses.
# AI_TRANSLATION_ENDPOINT=""

# Some OpenAI-compatible providers do not support response_format.
# Set this to false if your provider rejects response_format.
AI_TRANSLATION_RESPONSE_FORMAT="true"

# Backward-compatible legacy OpenAI vars are still supported:
# OPENAI_API_KEY=""
# OPENAI_TRANSLATION_MODEL=""
